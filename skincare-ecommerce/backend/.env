# ──────────────────────────────────────────────
# Lumière Skincare — Environment Configuration
# Copy this file to .env before running the app
# ──────────────────────────────────────────────

# Server
PORT=5000
NODE_ENV=development

# MongoDB — local MongoDB instance (default)
MONGO_URI=mongodb://localhost:27017/skincare_ecommerce

# JWT Secret — CHANGE THIS in production!
JWT_SECRET=lumiere_skincare_super_secret_jwt_key_2025

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5000
